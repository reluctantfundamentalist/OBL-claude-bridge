# ── Telegram (optional — keep if you use Telegram alongside Feishu) ─────────
# Required for hooks/stop.py Telegram delivery and cron telegram-notify.sh
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Feishu / Lark ─────────────────────────────────────────────────────────────
# Required for Feishu inbound (feishu_proxy.py) and outbound (stop_feishu.py)
# Create a Feishu custom app at https://open.feishu.cn/app

# App credentials (from Feishu developer console → Credentials & Basic Info)
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# Verification token (from Feishu developer console → Event Subscriptions)
# Used to validate that webhook events are genuinely from Feishu
FEISHU_VERIFICATION_TOKEN=

# Encrypt key (optional — set if you enable message encryption in Feishu console)
FEISHU_ENCRYPT_KEY=

# Port for feishu_proxy.py webhook server (default: 5200)
FEISHU_PROXY_PORT=5200

# Comma-separated allowlist of Feishu chat IDs (leave empty to allow all)
# Get chat_id from Feishu event logs or from the first message the proxy receives
FEISHU_ALLOWED_CHAT_IDS=

# ── Bridge settings ───────────────────────────────────────────────────────────
# Bridge install directory (defaults to the repo root)
BRIDGE_DIR=

# Log directory (defaults to $HOME/onyx-claude-logs)
BRIDGE_LOG_DIR=

# tmux session name for the persistent Claude Code session
BRIDGE_SESSION_NAME=onyx-claude

# tmux window index to target (always 0 for the Claude window)
BRIDGE_WINDOW=0
