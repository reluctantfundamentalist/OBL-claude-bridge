# Telegram bot token — get from @BotFather on Telegram
# Required for hooks/stop.py auto-delivery and cron telegram-notify.sh
TELEGRAM_BOT_TOKEN=

# Telegram chat ID — your DM chat ID (get from @userinfobot or your bot's getUpdates)
# Used as the default delivery target for cron jobs
TELEGRAM_CHAT_ID=

# Bridge install directory (defaults to $HOME/onyx-claude-bridge if unset)
BRIDGE_DIR=

# Log directory (defaults to $HOME/onyx-claude-logs if unset)
BRIDGE_LOG_DIR=
